# OpenTicket Environment Configuration

# Database URL:
# - SQLite (Default): sqlite:///./openticket.db
# - PostgreSQL (For High Traffic/Presales): postgresql://user:password@localhost:5432/openticket
DATABASE_URL=sqlite:///./openticket.db

# Stripe Payment Gateway settings:
STRIPE_API_KEY=sk_test_your_secret_stripe_api_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret

# Server settings:
PORT=8000
TESTING=False
